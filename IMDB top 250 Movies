"""
IMDB Top 250 Movies Scraper
Fetches and exports IMDB's top 250 movies with ratings to a CSV file.

Source: https://www.imdb.com/chart/top/?ref_=nv_mv_250
"""

from __future__ import annotations
import csv
import requests
from bs4 import BeautifulSoup

def get_imdb_top_250_movies(url: str = "") -> dict[str, float]:
    """
    Scrapes IMDB Top 250 movies from the given URL.
    
    Args:
        url (str): IMDB Top 250 movies URL. Uses default if not provided.
        
    Returns:
        dict[str, float]: Dictionary with movie titles as keys and ratings as values.
        
    Raises:
        requests.RequestException: If the HTTP request fails.
        AttributeError: If HTML parsing fails.
    """
    url = url or "https://www.imdb.com/chart/top/?ref_=nv_mv_250"
    
    try:
        response = requests.get(url, timeout=10)
        response.raise_for_status()
    except requests.RequestException as e:
        print(f"Error fetching the webpage: {e}")
        return {}
    
    try:
        soup = BeautifulSoup(response.text, "html.parser")
        titles = soup.find_all("td", attrs="titleColumn")
        ratings = soup.find_all("td", class_="ratingColumn imdbRating")
        
        movies = {
            title.a.text: float(rating.strong.text)
            for title, rating in zip(titles, ratings)
        }
        return movies
    except (AttributeError, ValueError) as e:
        print(f"Error parsing HTML: {e}")
        return {}

def write_movies(filename: str = "IMDb_Top_250_Movies.csv") -> None:
    """
    Fetches IMDB Top 250 movies and writes them to a CSV file.
    Also prints the results to console.
    
    Args:
        filename (str): Output CSV filename. Defaults to "IMDb_Top_250_Movies.csv".
    """
    movies = get_imdb_top_250_movies()
    
    if not movies:
        print("Failed to retrieve movies data.")
        return
    
    print(f"\n{'Rank':<6} {'Movie Title':<50} {'Rating':<8}")
    print("=" * 64)
    
    try:
        with open(filename, "w", newline="", encoding="utf-8") as out_file:
            writer = csv.writer(out_file)
            writer.writerow(["Rank", "Movie Title", "IMDb Rating"])
            
            for rank, (title, rating) in enumerate(movies.items(), start=1):
                print(f"{rank:<6} {title:<50} {rating:<8}")
                writer.writerow([rank, title, rating])
        
        print("=" * 64)
        print(f"\n✅ Successfully saved {len(movies)} movies to {filename}")
    except IOError as e:
        print(f"Error writing to file: {e}")

if __name__ == "__main__":
    write_movies()
